    "provenance": true
  },
  "scripts": {
    "start": "node server.js",
    "test": "node --test test/*.test.js",
    "audit:prod": "npm audit --omit=dev"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.76"
  },
  "overrides": {
    "@hono/node-server": "2.0.10"
  }
}
