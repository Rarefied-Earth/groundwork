{
  "name": "@rarefied-earth/groundwork-discovery-mcp",
  "version": "1.7.0",
  "private": false,
  "description": "Static local Rarefied Earth Groundwork MCP discovery server for registries and evaluation.",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "groundwork-discovery-mcp": "server.js"
  },
  "files": [
    "server.js",
    "benchmark",
    "docs",
    "LICENSE",
    "NOTICE.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Rarefied-Earth/groundwork.git"
  },
  "homepage": "https://rarefied.earth/groundwork/",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "company-memory",
    "agent-context",
    "rarefied-earth"
  ],
  "publishConfig": {
